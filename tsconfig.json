{
  "compilerOptions": {
    "baseUrl": "src",
    "outDir": "./dist",
    "target": "ES6",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "inlineSourceMap": true,
    "importHelpers": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["DOM", "ES5", "ES6", "ES2015"]
  },
  "include": ["src/**/*.ts"]
}
